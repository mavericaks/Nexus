# ──────────────────────────────────────────────────────────────────
# Nexus — Environment Variables
# Copy this to .env and fill in real values as each phase needs them.
# NEVER commit .env itself — it's gitignored (see .gitignore).
# NEVER put fake-but-plausible values here — empty placeholders only.
# ──────────────────────────────────────────────────────────────────

# ─── Local Docker Compose (defaults built into docker-compose.yml) ───
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Phase 1: Neon Postgres (production/remote database) ────────────
DATABASE_URL=
APP_DATABASE_URL=

# ─── Phase 3: Authentication ────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# ─── Phase 4: AI / LLM ─────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ─── Phase 4: Object Storage (if KB upload is built) ────────────────
B2_KEY_ID=
B2_APP_KEY=

# ─── Phase 6: Redis (production — Upstash) ─────────────────────────
REDIS_URL=
REDIS_TOKEN=

# ─── Phase 7: Error Tracking (optional) ────────────────────────────
SENTRY_DSN=
